{
  "version": 2,
  "builds": [
    {
      "src": "nifty100/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "nifty100/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "nifty100.settings",
    "DJANGO_DEBUG": "False",
    "VERCEL": "1"
  }
}